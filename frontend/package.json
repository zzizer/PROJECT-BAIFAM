{
  "name": "supraledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:low": "NODE_OPTIONS='--max-old-space-size=1536' next dev",
    "dev:2gb": "NODE_OPTIONS='--max-old-space-size=2048' next dev",
    "dev:4gb": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "build:4gb": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:8gb": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "lint": "eslint .",
    "start": "next start",
    "eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "eslint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "generate-module-json": "node ./scripts/generate-module-json.mjs",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "^16.2.2",
    "react": "^19.1.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/d3-format": "^3.0.4",
    "@types/leaflet": "^1.9.18",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
